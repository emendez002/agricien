 setup and operation, and to troubleshoot any steps where something's not right. Please be patient and work with me so we cover all possible scenarios - often the cause of one issue is another setting or installation issue.&quot;,&quot;localMemory&quot;:true,&quot;themeId&quot;:&quot;messages&quot;,&quot;window&quot;:false,&quot;icon&quot;:&quot;&quot;,&quot;iconText&quot;:&quot;&quot;,&quot;iconTextDelay&quot;:1,&quot;iconAlt&quot;:&quot;AI Chatbot Avatar&quot;,&quot;iconPosition&quot;:&quot;bottom-right&quot;,&quot;centerOpen&quot;:false,&quot;width&quot;:&quot;&quot;,&quot;openDelay&quot;:&quot;&quot;,&quot;iconBubble&quot;:false,&quot;windowAnimation&quot;:&quot;zoom&quot;,&quot;fullscreen&quot;:false,&quot;copyButton&quot;:false,&quot;headerSubtitle&quot;:&quot;Discuss with&quot;,&quot;containerType&quot;:&quot;standard&quot;,&quot;headerType&quot;:&quot;standard&quot;,&quot;messagesType&quot;:&quot;standard&quot;,&quot;inputType&quot;:&quot;standard&quot;,&quot;footerType&quot;:&quot;standard&quot;}' data-system='{&quot;botId&quot;:&quot;chatbot-68qg1g&quot;,&quot;customId&quot;:null,&quot;userData&quot;:null,&quot;sessionId&quot;:&quot;69d02e77c1bb6&quot;,&quot;restNonce&quot;:null,&quot;contextId&quot;:210309,&quot;pluginUrl&quot;:&quot;https:\\\/\\\/www.ditchassist.com\\\/wp-content\\\/plugins\\\/ai-engine-pro\\\/&quot;,&quot;restUrl&quot;:&quot;https:\\\/\\\/www.ditchassist.com\\\/wp-json&quot;,&quot;stream&quot;:false,&quot;debugMode&quot;:false,&quot;eventLogs&quot;:false,&quot;speech_recognition&quot;:false,&quot;speech_synthesis&quot;:false,&quot;typewriter&quot;:false,&quot;crossSite&quot;:false,&quot;actions&quot;:[],&quot;blocks&quot;:[],&quot;shortcuts&quot;:[]}' data-theme='{&quot;type&quot;:&quot;internal&quot;,&quot;name&quot;:&quot;Messages&quot;,&quot;themeId&quot;:&quot;messages&quot;,&quot;settings&quot;:[],&quot;style&quot;:&quot;&quot;,&quot;cssUrl&quot;:&quot;https:\\\/\\\/www.ditchassist.com\\\/wp-content\\\/plugins\\\/ai-engine-pro\\\/themes\\\/messages.css&quot;}'><\/div><\/div><\/div><\/div><\/div><div class=\"et_pb_row_2 et_pb_row et_flex_row\"><div class=\"et_pb_column_2 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_code_1 et_pb_code et_pb_module\"><div class=\"et_pb_code_inner\"><!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n<title>Markmap<\/title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n}\n#mindmap {\n  display: block;\n  width: 100vw;\n  height: 100vh;\n}\n<\/style>\n<link rel=\"stylesheet\" href=\"https:\/\/cdn.jsdelivr.net\/npm\/markmap-toolbar@0.16.0\/dist\/style.css\"><link rel=\"stylesheet\" href=\"https:\/\/cdn.jsdelivr.net\/npm\/katex@0.16.8\/dist\/katex.min.css\">\n<\/head>\n<body data-rsssl=1 data-rsssl=1>\n<svg id=\"mindmap\"><\/svg>\n<script src=\"https:\/\/cdn.jsdelivr.net\/npm\/d3@7.8.5\/dist\/d3.min.js\"><\/script><script src=\"https:\/\/cdn.jsdelivr.net\/npm\/markmap-view@0.16.0\/dist\/browser\/index.js\"><\/script><script src=\"https:\/\/cdn.jsdelivr.net\/npm\/markmap-toolbar@0.16.0\/dist\/index.js\"><\/script><script>(e=>{window.WebFontConfig={custom:{families:[\"KaTeX_AMS\",\"KaTeX_Caligraphic:n4,n7\",\"KaTeX_Fraktur:n4,n7\",\"KaTeX_Main:n4,n7,i4,i7\",\"KaTeX_Math:i4,i7\",\"KaTeX_Script\",\"KaTeX_SansSerif:n4,n7,i4\",\"KaTeX_Size1\",\"KaTeX_Size2\",\"KaTeX_Size3\",\"KaTeX_Size4\",\"KaTeX_Typewriter\"]},active:()=>{e().refreshHook.call()}}})(()=>window.markmap)<\/script><script src=\"https:\/\/cdn.jsdelivr.net\/npm\/webfontloader@1.6.28\/webfontloader.js\" defer><\/script><script>(()=>{setTimeout(()=>{const{markmap:H,mm:ae}=window,W=new H.Toolbar;W.attach(ae);const we=W.render();we.setAttribute(\"style\",\"position:absolute;bottom:20px;right:20px\"),document.body.append(we)})})()<\/script><script>((o,T,c,r)=>{const g=o();window.mm=g.Markmap.create(\"svg#mindmap\",(T||g.deriveOptions)(r),c)})(()=>window.markmap,null,{\"content\":\"\",\"children\":[{\"content\":\"<strong>Step 1: Is Ditch Assist Module Powered ON?<\/strong>\",\"children\":[{\"content\":\"Yes: Proceed to step 2.\",\"children\":[],\"payload\":{\"lines\":\"1,2\"}},{\"content\":\"No: Power ON the module.\",\"children\":[],\"payload\":{\"lines\":\"2,3\"}}],\"payload\":{\"lines\":\"0,3\"}},{\"content\":\"<strong>Step 2: Is the tablet Connected to DA Module WiFi?<\/strong>\",\"children\":[{\"content\":\"Yes: Go to step 3.\",\"children\":[],\"payload\":{\"lines\":\"4,5\"}},{\"content\":\"No: Connect tablet to DA WiFi.\",\"children\":[],\"payload\":{\"lines\":\"5,6\"}}],\"payload\":{\"lines\":\"3,6\"}},{\"content\":\"<strong>Step 3: Open DA App and Connect WiFi. Does DA module serial # display in app?<\/strong>\",\"children\":[{\"content\":\"Yes: Move to step 4.\",\"children\":[],\"payload\":{\"lines\":\"7,8\"}},{\"content\":\"No:\",\"children\":[{\"content\":\"Ensure tablet is connected to DA Wi-Fi.\",\"children\":[],\"payload\":{\"lines\":\"9,10\"}},{\"content\":\"Ensure no other devices are connected to DA WiFi.\",\"children\":[],\"payload\":{\"lines\":\"10,11\"}},{\"content\":\"Power cycle DA module and retry.\",\"children\":[{\"content\":\"If connects, proceed to step 4 if another issue is present.\",\"children\":[],\"payload\":{\"lines\":\"12,13\"}},{\"content\":\"If doesn\u2019t connect, bring tablet closer to DA module and try again.\",\"children\":[{\"content\":\"If connects, move further away and test again. If still connects, proceed to step 4 if another issue is present.\",\"children\":[],\"payload\":{\"lines\":\"14,15\"}},{\"content\":\"If doesn\u2019t connect, test with another Android device.\",\"children\":[{\"content\":\"If connects, possible issue with original tablet\/device. Proceed to step 4 if another issue is present.\",\"children\":[],\"payload\":{\"lines\":\"16,17\"}},{\"content\":\"If doesn\u2019t connect, return DA module for service\/replacement.\",\"children\":[],\"payload\":{\"lines\":\"17,18\"}}],\"payload\":{\"lines\":\"15,18\"}}],\"payload\":{\"lines\":\"13,18\"}}],\"payload\":{\"lines\":\"11,18\"}}],\"payload\":{\"lines\":\"8,18\"}}],\"payload\":{\"lines\":\"6,18\"}},{\"content\":\"<strong>Step 4: Does GNSS info populate on left pane in DA app?<\/strong>\",\"children\":[{\"content\":\"Yes: Proceed to step 5.\",\"children\":[],\"payload\":{\"lines\":\"19,20\"}},{\"content\":\"No:\",\"children\":[{\"content\":\"Confirm GPS is powered ON.\",\"children\":[],\"payload\":{\"lines\":\"21,22\"}},{\"content\":\"Ensure GPS is set to output only GGA & VTG NMEA messages. Turn OFF all others.\",\"children\":[],\"payload\":{\"lines\":\"22,23\"}},{\"content\":\"Confirm GGA and VTG messages are 5Hz or 10Hz.\",\"children\":[],\"payload\":{\"lines\":\"23,24\"}},{\"content\":\"Set GPS Baud Rate to 38,400.\",\"children\":[],\"payload\":{\"lines\":\"24,25\"}},{\"content\":\"Ensure NMEA messages use Talker ID <span class=\\\"katex\\\"><span class=\\\"katex-mathml\\\"><math xmlns=\\\"http:\/\/www.w3.org\/1998\/Math\/MathML\\\"><semantics><mrow><mi>G<\/mi><mi>P<\/mi><mi>o<\/mi><mi>r<\/mi><\/mrow><annotation encoding=\\\"application\/x-tex\\\">GP or<\/annotation><\/semantics><\/math><\/span><span class=\\\"katex-html\\\" aria-hidden=\\\"true\\\"><span class=\\\"base\\\"><span class=\\\"strut\\\" style=\\\"height:0.6833em;\\\"><\/span><span class=\\\"mord mathnormal\\\" style=\\\"margin-right:0.13889em;\\\">GP<\/span><span class=\\\"mord mathnormal\\\" style=\\\"margin-right:0.02778em;\\\">or<\/span><\/span><\/span><\/span>GN.\",\"children\":[],\"payload\":{\"lines\":\"25,26\"}},{\"content\":\"Check if Status 1 or 2 light on DA module is blinking.\",\"children\":[{\"content\":\"If yes, verify settings again, turn off all but GGA, and ensure no additional messages are turned on.\",\"children\":[],\"payload\":{\"lines\":\"27,28\"}},{\"content\":\"If no, check GPS cable connection to DA harness, verify correct NMEA settings, inspect pins on GPS and main harnesses, and switch pin 2 and 3 on GPS Deutsch connector.\",\"children\":[],\"payload\":{\"lines\":\"28,29\"}},{\"content\":\"Test again. If GPS info displays, proceed to step 5 if another issue is present. If no GPS info, check if Status 1 or 2 flash. If yes, it's a GPS config\/message issue. If no, test with another harness and DA module to identify the issue.\",\"children\":[],\"payload\":{\"lines\":\"29,30\"}}],\"payload\":{\"lines\":\"26,30\"}}],\"payload\":{\"lines\":\"20,30\"}}],\"payload\":{\"lines\":\"18,30\"}},{\"content\":\"<strong>Step 5: Does GNSS info panel display RTK status?<\/strong>\",\"children\":[{\"content\":\"Yes: Proceed to step 6.\",\"children\":[],\"payload\":{\"lines\":\"31,32\"}},{\"content\":\"No:\",\"children\":[{\"content\":\"If using non-RTK correction, proceed to step 6.\",\"children\":[],\"payload\":{\"lines\":\"33,34\"}},{\"content\":\"If RTK not correctly configured, configure GPS for RTK.\",\"children\":[],\"payload\":{\"lines\":\"34,35\"}}],\"payload\":{\"lines\":\"32,35\"}}],\"payload\":{\"lines\":\"30,35\"}},{\"content\":\"<strong>Step 6: When stationary, does GPS hold RTK fix?<\/strong>\",\"children\":[{\"content\":\"Yes: Proceed to step 7.\",\"children\":[],\"payload\":{\"lines\":\"36,37\"}},{\"content\":\"No, jumps between RTK, FLOAT, AUTONOMOUS\",\"children\":[{\"content\":\"Check RTK system for\",\"children\":[{\"content\":\"radio\/modem issues\",\"children\":[],\"payload\":{\"lines\":\"39,40\"}},{\"content\":\"loose cables\",\"children\":[],\"payload\":{\"lines\":\"40,41\"}},{\"content\":\"distance from base\",\"children\":[],\"payload\":{\"lines\":\"41,42\"}},{\"content\":\"poor cell signal for CORS\/VRS\",\"children\":[],\"payload\":{\"lines\":\"42,43\"}},{\"content\":\"GPS antenna obstruction\",\"children\":[],\"payload\":{\"lines\":\"43,44\"}},{\"content\":\"solar storm status\",\"children\":[],\"payload\":{\"lines\":\"44,45\"}}],\"payload\":{\"lines\":\"38,45\"}}],\"payload\":{\"lines\":\"37,45\"}}],\"payload\":{\"lines\":\"35,45\"}},{\"content\":\"<strong>Step 7: When stationary, does the UPDATE ON value change approximately every second?<\/strong>\",\"children\":[{\"content\":\"Yes: Proceed to step 8.\",\"children\":[],\"payload\":{\"lines\":\"46,47\"}},{\"content\":\"No, updates at an irrational rate or not at all\",\"children\":[{\"content\":\"Indicates a GPS connection timeout\",\"children\":[{\"content\":\"check for another NMEA message turned on\",\"children\":[],\"payload\":{\"lines\":\"49,50\"}},{\"content\":\"Confirm DA or GPS power connection to vehicle battery\",\"children\":[],\"payload\":{\"lines\":\"50,51\"}},{\"content\":\"Confirm NMEA messages using Talker ID <span class=\\\"katex\\\"><span class=\\\"katex-mathml\\\"><math xmlns=\\\"http:\/\/www.w3.org\/1998\/Math\/MathML\\\"><semantics><mrow><mi>G<\/mi><mi>P<\/mi><mi>o<\/mi><mi>r<\/mi><\/mrow><annotation encoding=\\\"application\/x-tex\\\">GP or<\/annotation><\/semantics><\/math><\/span><span class=\\\"katex-html\\\" aria-hidden=\\\"true\\\"><span class=\\\"base\\\"><span class=\\\"strut\\\" style=\\\"height:0.6833em;\\\"><\/span><span class=\\\"mord mathnormal\\\" style=\\\"margin-right:0.13889em;\\\">GP<\/span><span class=\\\"mord mathnormal\\\" style=\\\"margin-right:0.02778em;\\\">or<\/span><\/span><\/span><\/span>GN\",\"children\":[],\"payload\":{\"lines\":\"51,52\"}},{\"content\":\"Test with another DA module & harness.\",\"children\":[{\"content\":\"If not working GPS may be incompatible with DA (very rare, probably a setting issue)\",\"children\":[],\"payload\":{\"lines\":\"53,54\"}},{\"content\":\"Test GPS with a non-DA device\/system using NMEA.\",\"children\":[],\"payload\":{\"lines\":\"54,55\"}}],\"payload\":{\"lines\":\"52,55\"}}],\"payload\":{\"lines\":\"48,55\"}}],\"payload\":{\"lines\":\"47,55\"}}],\"payload\":{\"lines\":\"45,55\"}},{\"content\":\"<strong>Step 8: When stationary, does elevation value change?<\/strong>\",\"children\":[{\"content\":\"Yes, very slightly: GPS appears good, continue to step 9.\",\"children\":[],\"payload\":{\"lines\":\"56,57\"}},{\"content\":\"Yes, changes significantly\",\"children\":[{\"content\":\"Check for signal obstruction and RTK connection issues.\",\"children\":[],\"payload\":{\"lines\":\"58,59\"}}],\"payload\":{\"lines\":\"57,59\"}},{\"content\":\"No\",\"children\":[{\"content\":\"Possibly another NMEA message is turned on\",\"children\":[],\"payload\":{\"lines\":\"60,61\"}},{\"content\":\"Confirm NMEA messages are using Talker ID GP or GN\",\"children\":[],\"payload\":{\"lines\":\"61,62\"}},{\"content\":\"Perform previous GPS troubleshooting steps\",\"children\":[],\"payload\":{\"lines\":\"62,63\"}}],\"payload\":{\"lines\":\"59,63\"}}],\"payload\":{\"lines\":\"55,63\"}},{\"content\":\"<strong>Step 9: Are implement hydraulics connected to DA proportional valve?<\/strong>\",\"children\":[{\"content\":\"Yes: Continue to step 10.\",\"children\":[],\"payload\":{\"lines\":\"64,65\"}},{\"content\":\"No: Connect hydraulics.\",\"children\":[],\"payload\":{\"lines\":\"65,66\"}}],\"payload\":{\"lines\":\"63,66\"}},{\"content\":\"<strong>Step 10: Does the implement circuit have constant flow enabled?<\/strong>\",\"children\":[{\"content\":\"Yes: Move to step 11.\",\"children\":[],\"payload\":{\"lines\":\"67,68\"}},{\"content\":\"No: Enable constant flow.\",\"children\":[],\"payload\":{\"lines\":\"68,69\"}}],\"payload\":{\"lines\":\"66,69\"}},{\"content\":\"<strong>Step 11: Can the implement be moved UP\/DOWN using Manual Raise Lower on app?<\/strong>\",\"children\":[{\"content\":\"Yes: Move to step 12.\",\"children\":[],\"payload\":{\"lines\":\"70,71\"}},{\"content\":\"Yes, but too slow\",\"children\":[{\"content\":\"Increase hydraulic flow from tractor\",\"children\":[],\"payload\":{\"lines\":\"72,73\"}},{\"content\":\"Adjust Response Sensitivity settings\",\"children\":[],\"payload\":{\"lines\":\"73,74\"}},{\"content\":\"If a very large implement, may require a high flow valve.\",\"children\":[],\"payload\":{\"lines\":\"74,75\"}}],\"payload\":{\"lines\":\"71,75\"}},{\"content\":\"No\",\"children\":[{\"content\":\"Check valve connection to DA harness\",\"children\":[],\"payload\":{\"lines\":\"76,77\"}},{\"content\":\"Ensure hydraulic connectors are seated\",\"children\":[],\"payload\":{\"lines\":\"77,78\"}},{\"content\":\"Increase hydraulic flow\",\"children\":[],\"payload\":{\"lines\":\"78,79\"}},{\"content\":\"Verify \u2018Commands to Controller\u2019 is checked in Settings\",\"children\":[],\"payload\":{\"lines\":\"79,80\"}},{\"content\":\"Adjust Response Sensitivity settings\",\"children\":[],\"payload\":{\"lines\":\"80,81\"}},{\"content\":\"Reverse hydraulic flow direction\",\"children\":[],\"payload\":{\"lines\":\"81,82\"}},{\"content\":\"Test for voltage signal at the valve\",\"children\":[],\"payload\":{\"lines\":\"82,83\"}}],\"payload\":{\"lines\":\"75,83\"}}],\"payload\":{\"lines\":\"69,83\"}},{\"content\":\"<strong>Step 12: In a safe open area, raise implement to 50% travel. Set target grade to 0. On Ditch Mode screen, hit START. Does implement move?<\/strong>\",\"children\":[{\"content\":\"Yes, very small movements: Proceed to step 13.\",\"children\":[],\"payload\":{\"lines\":\"84,85\"}},{\"content\":\"Yes, significant travel\",\"children\":[{\"content\":\"Perform previous GPS checks and confirm GPS settings.\",\"children\":[],\"payload\":{\"lines\":\"86,87\"}}],\"payload\":{\"lines\":\"85,87\"}},{\"content\":\"No: Proceed to step 13.\",\"children\":[],\"payload\":{\"lines\":\"87,88\"}}],\"payload\":{\"lines\":\"83,88\"}},{\"content\":\"<strong>Step 13: With auto grading running, Nudge Up and Down to increase\/decrease target by 6\u201d. Does implement move?<\/strong>\",\"children\":[{\"content\":\"Implement moves 6\u201d and holds: Everything seems good. Move to step 14.\",\"children\":[],\"payload\":{\"lines\":\"89,90\"}},{\"content\":\"Implement overshoots or begins to bunnyhop\",\"children\":[{\"content\":\"Confirm GPS settings\",\"children\":[{\"content\":\"GGA message minimum 5Hz (NOT 1Hz)\",\"children\":[],\"payload\":{\"lines\":\"92,93\"}}],\"payload\":{\"lines\":\"91,93\"}},{\"content\":\"Check hydraulic settings\",\"children\":[{\"content\":\"Turn down tractor flow\",\"children\":[],\"payload\":{\"lines\":\"94,95\"}},{\"content\":\"Reduce Min\/Max DC Settings\",\"children\":[],\"payload\":{\"lines\":\"95,96\"}},{\"content\":\"Verify correct Open\/Closed center setup\",\"children\":[],\"payload\":{\"lines\":\"96,97\"}}],\"payload\":{\"lines\":\"93,97\"}},{\"content\":\"Ensure power supply is connected to tractor battery.\",\"children\":[],\"payload\":{\"lines\":\"97,98\"}}],\"payload\":{\"lines\":\"90,98\"}},{\"content\":\"Implement doesn\u2019t move\",\"children\":[{\"content\":\"Increase hydraulic flow\",\"children\":[],\"payload\":{\"lines\":\"99,100\"}},{\"content\":\"Increase Min\/Max valve DC settings\",\"children\":[],\"payload\":{\"lines\":\"100,101\"}},{\"content\":\"Verify correct Open\/Closed center setup\",\"children\":[],\"payload\":{\"lines\":\"101,102\"}}],\"payload\":{\"lines\":\"98,102\"}}],\"payload\":{\"lines\":\"88,102\"}},{\"content\":\"<strong>Step 14: When operating in the field, does the system work correctly for prolonged periods?<\/strong>\",\"children\":[{\"content\":\"Yes: System appears fully operational.\",\"children\":[],\"payload\":{\"lines\":\"103,104\"}},{\"content\":\"No, automatic control stops or becomes unresponsive\",\"children\":[{\"content\":\"Verify no additional WiFi connections to DA module (e.g. a cell phone)\",\"children\":[],\"payload\":{\"lines\":\"105,106\"}},{\"content\":\"Ensure power harness is connected directly to vehicle battery\",\"children\":[],\"payload\":{\"lines\":\"106,107\"}},{\"content\":\"Check all cable connections\",\"children\":[],\"payload\":{\"lines\":\"107,108\"}},{\"content\":\"Troubleshoot GPS signal\",\"children\":[],\"payload\":{\"lines\":\"108,109\"}},{\"content\":\"Power cycle all components\",\"children\":[],\"payload\":{\"lines\":\"109,110\"}},{\"content\":\"Reinstall DA app\",\"children\":[],\"payload\":{\"lines\":\"110,111\"}},{\"content\":\"Test with a different tablet\",\"children\":[],\"payload\":{\"lines\":\"111,112\"}},{\"content\":\"Test with different DA control module\",\"children\":[],\"payload\":{\"lines\":\"112,113\"}}],\"payload\":{\"lines\":\"104,113\"}},{\"content\":\"No, system gets slow and stops responding after several hours\",\"children\":[{\"content\":\"Consider upgrading tablet\",\"children\":[],\"payload\":{\"lines\":\"114,115\"}},{\"content\":\"Rebooting tablet every few hours\",\"children\":[],\"payload\":{\"lines\":\"115,116\"}},{\"content\":\"Turn off Draw Markers on Map in Settings\",\"children\":[],\"payload\":{\"lines\":\"116,117\"}},{\"content\":\"Reducing design resolution if using land level design\",\"children\":[],\"payload\":{\"lines\":\"117,118\"}},{\"content\":\"Periodically reboot tablet to clear memory.\",\"children\":[],\"payload\":{\"lines\":\"118,119\"}}],\"payload\":{\"lines\":\"113,119\"}}],\"payload\":{\"lines\":\"102,119\"}}],\"payload\":{\"lines\":\"0,119\"}},null)<\/script>\n<\/body>\n<\/html>\n<\/div><\/div><\/div><\/div><\/div>","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"footnotes":""},"class_list":["post-210309","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/pages\/210309","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/comments?post=210309"}],"version-history":[{"count":5,"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/pages\/210309\/revisions"}],"predecessor-version":[{"id":213159,"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/pages\/210309\/revisions\/213159"}],"wp:attachment":[{"href":"https:\/\/www.ditchassist.com\/wp-json\/wp\/v2\/media?parent=210309"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}