_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_4 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">How to Install Ditch Assist Hardware<\/h3>\n<\/div><\/div><div class=\"et_pb_video_1 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Ditch_Assist_Setup.mp4\" src=\"https:\/\/player.vimeo.com\/video\/705489581?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"608\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_5 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Learn how easy it is to install Ditch Assist on any implement and connect it to any tractor<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_5 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_6 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">How to Install Ditch Assist X Hardware<\/h3>\n<\/div><\/div><div class=\"et_pb_video_2 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"DAX_install.mp4\" src=\"https:\/\/player.vimeo.com\/video\/712408479?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"608\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_7 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Learn how easy it is to install Ditch Assist X on any excavator, backhoe, or mini hoe<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_4 et_pb_row et_flex_row\"><div class=\"et_pb_column_6 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_8 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Installing &amp; Running the Ditch Assist App for the First Time<\/h3>\n<\/div><\/div><div class=\"et_pb_video_3 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"DA Install App Cache Imagery Connect WiFi\" src=\"https:\/\/player.vimeo.com\/video\/712209077?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"585\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_9 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">How to install, run, and connect the Ditch Assist App to the Control Module via Wi-Fi<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_7 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_10 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Configuring Ditch Assist Settings via the Ditch Assist App<\/h3>\n<\/div><\/div><div class=\"et_pb_video_4 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"DA How to Settings Complete\" src=\"https:\/\/player.vimeo.com\/video\/712209045?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"585\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_11 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Learn about the settings you need to configure via the Ditch Assist App before using Ditch Assist<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_5 et_pb_row et_flex_row\"><div class=\"et_pb_column_8 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_12 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h2 style=\"text-align: left;\">Everyday Operation of Ditch Assist and Ditch Assist X<\/h2>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_6 et_pb_row et_flex_row\"><div class=\"et_pb_column_9 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_13 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Ditch Assist Operator Masterclass - Slope-IQ<\/h3>\n<\/div><\/div><div class=\"et_pb_video_5 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Overview of Ditch Assist with Slope IQ\" src=\"https:\/\/player.vimeo.com\/video\/882256394?dnt=1&amp;app_id=122963\" width=\"563\" height=\"1000\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_14 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">How to use Ditch Assist and Slope-IQ to create effective field drains every time<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_10 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_15 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Using Ditch Assist for Side Slopes<\/h3>\n<\/div><\/div><div class=\"et_pb_video_6 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Creating Side Slopes with Ditch Assist\" src=\"https:\/\/player.vimeo.com\/video\/882259240?dnt=1&amp;app_id=122963\" width=\"563\" height=\"1000\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_16 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Ditch Assist isn't just great for ditch bottoms - it also works for your side slopes too!<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_7 et_pb_row et_flex_row\"><div class=\"et_pb_column_11 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_17 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Ditch Survey &amp; Design Process<\/h3>\n<\/div><\/div><div class=\"et_pb_video_7 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"DA How to Run Survey Design Implement.mp4\" src=\"https:\/\/player.vimeo.com\/video\/712208991?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"585\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_18 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">This video demonstrates how to use Ditch Assist for a typical survey and best-fit ditch design using Slope-IQ<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_12 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_19 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Creating Customized Designs<\/h3>\n<\/div><\/div><div class=\"et_pb_video_8 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"How to use design customizer\" src=\"https:\/\/player.vimeo.com\/video\/882248365?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"628\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_20 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">In this video you'll learn how to use the new Design Customizer in Slope-IQ to create a fully custom design for ditches or tile runs<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_13 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_21 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Recall Previous Surveys<\/h3>\n<\/div><\/div><div class=\"et_pb_video_9 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Recall Previous Surveys\" src=\"https:\/\/player.vimeo.com\/video\/882248400?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"628\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_22 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">All surveys on Ditch Assist are stored in your tablet's internal memory for access in the future. Learn how with our this video demo.<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_8 et_pb_row et_flex_row\"><div class=\"et_pb_column_14 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_23 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">How to Load a Georeferenced Image Overlay<\/h3>\n<\/div><\/div><div class=\"et_pb_video_10 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"How to load a Georeferenced Image\" src=\"https:\/\/player.vimeo.com\/video\/882248342?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"628\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_24 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Learn how to import a geo image overlay such as an elevation map or cut fill map and display it on the Ditch Assist map screen<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_15 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_25 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Using the NEW Image Overlay Georeference Tool<\/h3>\n<\/div><\/div><div class=\"et_pb_video_11 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"New Image Georeference Tool\" src=\"https:\/\/player.vimeo.com\/video\/882248382?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"508\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_26 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">With our new tool located at <a href=\"https:\/\/www.ditchassist.com\/geo\/\">https:\/\/www.ditchassist.com\/geo\/<\/a> you can import ANY map or image from your computer as an overlay in Ditch Assist. Learn how here!<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_9 et_pb_row et_flex_row\"><div class=\"et_pb_column_16 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_27 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Importing Ideal Drainage Maps from PC to Ditch Assist App<\/h3>\n<\/div><\/div><div class=\"et_pb_video_12 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"How to Download IDM to PC and Import to DA\" src=\"https:\/\/player.vimeo.com\/video\/882261045?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"622\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_28 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">How to import kml files such as Ideal Drainage Mapping data into Ditch Assist as a map overlay<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_17 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_29 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Direct Download Ideal Drainage Map Data to your Tablet<\/h3>\n<\/div><\/div><div class=\"et_pb_video_13 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Downloading IDM Direct to Tablet\" src=\"https:\/\/player.vimeo.com\/video\/882261026?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"622\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_30 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">If you are downloading IDM layers directly from our online portal to your tablet, it's essential to watch this video to ensure the display of flow maps in Ditch Assist.<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_10 et_pb_row et_flex_row\"><div class=\"et_pb_column_18 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_31 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h2 style=\"text-align: left;\">Advanced Operation of Ditch Assist and Ditch Assist X<\/h2>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_11 et_pb_row et_flex_row\"><div class=\"et_pb_column_19 et_pb_column et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_32 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">The Concept of Tiling with Ditch Assist<\/h3>\n<\/div><\/div><div class=\"et_pb_video_14 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Tiling_with_Ditch_Assist_Concepts.mp4\" src=\"https:\/\/player.vimeo.com\/video\/712235072?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"608\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_33 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">Ditch Assist can be used with most pull-type and mounted tile plows. Here's an overview<\/p>\n<\/div><\/div><\/div><div class=\"et_pb_column_20 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_34 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Using Ditch Assist with a Tile Plow<\/h3>\n<\/div><\/div><div class=\"et_pb_video_15 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Joel Tiling with DA Demo.mp4\" src=\"https:\/\/player.vimeo.com\/video\/712204474?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"608\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_35 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">In this video, Joel demonstrates how to use Ditch Assist to tile with a Soil-Max tile plow<\/p>\n<\/div><\/div><\/div><\/div><div class=\"et_pb_row_12 et_pb_row et_flex_row\"><div class=\"et_pb_column_21 et_pb_column et-last-child et_flex_column et_pb_css_mix_blend_mode_passthrough et_flex_column_24_24 et_flex_column_24_24_tablet et_flex_column_24_24_phone\"><div class=\"et_pb_text_36 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Create and Import a Geo-Image Overlay (Advanced GIS Users)<\/h3>\n<\/div><\/div><div class=\"et_pb_video_16 et_pb_video et_pb_module et_flex_module\"><div class=\"et_pb_video_box\"><iframe loading=\"lazy\" title=\"Import an image overlay.mp4\" src=\"https:\/\/player.vimeo.com\/video\/712244414?dnt=1&amp;app_id=122963\" width=\"1080\" height=\"608\" frameborder=\"0\" allow=\"autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\"><\/iframe><\/div><\/div><div class=\"et_pb_text_37 et_pb_text et_pb_bg_layout_light et_pb_module et_flex_module\"><div class=\"et_pb_text_inner\"><p style=\"text-align: center;\">How to create and import a geo-referenced image overlay such as a cut fill map or drone imagery using QGIS<\/p>\n<\/div><\/div><\/div><\/div><\/div><div class=\"et_pb_section_1 et_pb_section et_section_regular et_flex_section\"><\/div>","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status"